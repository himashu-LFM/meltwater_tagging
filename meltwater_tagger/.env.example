# Copy to .env locally, or set these as environment variables on your host.

# Required — Anthropic API key (classification)
ANTHROPIC_API_KEY=sk-ant-...

# Model (optional). Sonnet is cheaper; Opus is most accurate.
MELTWATER_MODEL=claude-sonnet-4-6

# Reddit API (REQUIRED for cloud deploy — CDP/Chrome fetch is not available there).
# Create a free "script" app at https://old.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=cloud:meltwater-tagger:1.0 (by /u/your_username)

# On a cloud host, disable CDP so the UI uses the Reddit API path.
# Leave true (or unset) for local use with your logged-in Chrome.
MELTWATER_ALLOW_CDP=false

# --- Multi-user platform (auth, per-user creds, brands, history) ------------
# Create a free project at https://supabase.com, run supabase/schema.sql in
# its SQL Editor, then copy these from Project Settings -> API.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...           # safe to expose to the browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # SECRET — server-side only, never in frontend code

# Meltwater login URL used by the automated "Apply to Meltwater" button.
# Adjust if your org uses a different login entry point.
MELTWATER_LOGIN_URL=https://app.meltwater.com/login
